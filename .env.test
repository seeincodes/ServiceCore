# ===========================================
# ServiceCore - TEST Environment
# ===========================================

NODE_ENV=test
PORT=3001
CORS_ORIGIN=http://localhost:4200
LOG_LEVEL=warn

# Database (local Docker, separate test DB)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/timekeeper_test
DB_PORT=5433

# Redis (local Docker)
REDIS_URL=redis://localhost:6380

# Auth
JWT_SECRET=test-secret-for-automated-tests
JWT_EXPIRY=3600
REFRESH_TOKEN_EXPIRY=604800

# Encryption
APP_ENCRYPTION_KEY=abcdef0123456789abcdef0123456789abcdef0123456789abcdef0123456789

# All integrations disabled in test
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
SENDGRID_API_KEY=
SQS_NOTIFICATION_QUEUE_URL=
S3_EXPORTS_BUCKET=
QB_CLIENT_ID=
STRIPE_SECRET_KEY=
